FROM sonatype/nexus3:latest

USER 0

# Just the filter + config. No descriptor, no capability, no datastore check.
# Config is read from /nexus-data/etc/port-gate.conf (hot-reloadable).
RUN mkdir -p /tmp/src/com/sonatype/nexus/plugins/portgate /tmp/build /tmp/cp

RUN cat > /tmp/src/com/sonatype/nexus/plugins/portgate/PortGateFilter.java << 'JAVA'
package com.sonatype.nexus.plugins.portgate;
import java.io.IOException; import java.nio.file.*; import java.util.*;
import javax.inject.*; import javax.servlet.*; import javax.servlet.http.*;
import org.slf4j.*;
@Named @Singleton
public class PortGateFilter implements Filter {
    private static final Logger log = LoggerFactory.getLogger(PortGateFilter.class);
    private volatile int scopedPort = 8443;
    private volatile List<String> allowed = Collections.emptyList();

    public PortGateFilter() {
        // Watch config file for changes (hot reload, no restart)
        Thread t = new Thread(() -> {
            Path conf = Paths.get("/nexus-data/etc/port-gate.conf");
            loadConfig(conf);
            try (WatchService ws = FileSystems.getDefault().newWatchService()) {
                if (conf.getParent() != null) conf.getParent().register(ws, StandardWatchEventKinds.ENTRY_MODIFY);
                while (!Thread.currentThread().isInterrupted()) {
                    ws.take().pollEvents().forEach(e -> { if (e.context().toString().equals("port-gate.conf")) loadConfig(conf); });
                    ws.take().reset();
                }
            } catch (Exception e) { log.warn("Config watch stopped: {}", e.getMessage()); }
        });
        t.setDaemon(true); t.start();
    }

    private void loadConfig(Path conf) {
        try {
            List<String> lines = Files.readAllLines(conf);
            List<String> paths = new ArrayList<>();
            for (String l : lines) {
                String t = l.trim();
                if (t.isEmpty() || t.startsWith("#")) continue;
                if (t.startsWith("port=")) { scopedPort = Integer.parseInt(t.substring(5).trim()); }
                else paths.add(t);
            }
            allowed = Collections.unmodifiableList(paths);
            log.info("Port-gate loaded: port={}, {} paths", scopedPort, allowed.size());
        } catch (Exception e) {
            log.warn("Could not read {}: {}", conf, e.getMessage());
        }
    }

    public void init(FilterConfig f) { log.info("Port-gate filter initialised"); }

    public void doFilter(ServletRequest q, ServletResponse s, FilterChain c) throws IOException, ServletException {
        int port = q.getLocalPort();
        if (port == scopedPort) {
            String path = ((HttpServletRequest)q).getRequestURI();
            for (String p : allowed) if (path.startsWith(p)) { c.doFilter(q,s); return; }
            HttpServletResponse h = (HttpServletResponse)s;
            h.setStatus(403); h.setContentType("text/plain");
            h.getWriter().write("Port-gate: denied on port "+port+" for "+path+"\n");
            return;
        }
        c.doFilter(q,s);
    }
    public void destroy() {}
}
JAVA

# Compile
RUN cd /tmp/cp && jar xf /opt/sonatype/nexus/bin/sonatype-nexus-repository-*.jar BOOT-INF/lib && \
    cp BOOT-INF/lib/*.jar . && rm -rf BOOT-INF && \
    javac -cp "/tmp/cp/*" -d /tmp/build $(find /tmp/src -name '*.java') && \
    echo "Compiled $(find /tmp/build -name '*.class' | wc -l) classes"

# Package
RUN mkdir -p /tmp/build/META-INF/sisu && \
    printf "com.sonatype.nexus.plugins.portgate.PortGateFilter\n" > /tmp/build/META-INF/sisu/javax.inject.Named && \
    mkdir -p /opt/sonatype/nexus/plugins && \
    jar cf /opt/sonatype/nexus/plugins/port-gate-plugin.jar -C /tmp/build .

# loader.properties to add plugins dir
RUN printf "loader.path=BOOT-INF/classes,BOOT-INF/lib,/opt/sonatype/nexus/plugins\n" > /tmp/loader.properties && \
    cd /tmp && jar uf /opt/sonatype/nexus/bin/sonatype-nexus-repository-*.jar loader.properties

# Default config
RUN mkdir -p /nexus-data/etc && \
    printf "# Port-gate configuration\nport=8443\n/repository/maven-releases/\n/repository/maven-central/\n" > /nexus-data/etc/port-gate.conf && \
    chown -R nexus:nexus /nexus-data

RUN rm -rf /tmp/*

USER nexus
