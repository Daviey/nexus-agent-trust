{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "npm install*": "deny",
      "npm i *": "deny",
      "npm i": "deny",
      "npm ci*": "deny",
      "npm add*": "deny",
      "pnpm install*": "deny",
      "pnpm add*": "deny",
      "yarn install*": "deny",
      "yarn add*": "deny",
      "pip install*": "deny",
      "pip3 install*": "deny",
      "uv pip*": "deny",
      "pipx install*": "deny",
      "go install*": "deny",
      "go get*": "deny",
      "go mod download*": "deny",
      "cargo add*": "deny",
      "cargo install*": "deny",
      "cargo build*": "deny",
      "docker pull*": "deny",
      "npm-safe*": "allow",
      "pip-safe*": "allow",
      "go-safe*": "allow",
      "npm run*": "allow",
      "npm test*": "allow",
      "npm exec*": "allow",
      "npm ls*": "allow"
    }
  }
}
