FROM sonatype/nexus3:latest

USER 0

RUN mkdir -p /tmp/src/com/sonatype/nexus/plugins/portgate /tmp/build /tmp/cp

RUN cat > /tmp/src/com/sonatype/nexus/plugins/portgate/PortGateConfig.java << 'JAVA'
package com.sonatype.nexus.plugins.portgate;
import java.util.*; import java.util.concurrent.atomic.AtomicReference;
import javax.inject.*; import org.slf4j.*;
@Named @Singleton
public class PortGateConfig {
    private static final Logger log = LoggerFactory.getLogger(PortGateConfig.class);
    private final AtomicReference<Snapshot> current = new AtomicReference<>(new Snapshot(false, 0, Collections.emptyList()));
    void update(boolean e, int p, List<String> a) { current.set(new Snapshot(e, p, Collections.unmodifiableList(new ArrayList<>(a)))); log.info("Port-gate: port={}, {} repos", p, a.size()); }
    void clear() { current.set(new Snapshot(false, 0, Collections.emptyList())); }
    public boolean isEnabled() { return current.get().enabled; }
    public int getScopedPort() { return current.get().scopedPort; }
    public List<String> getAllowedPrefixes() { return current.get().allowedPrefixes; }
    static List<String> parseRepos(String r) {
        if (r == null || r.isBlank()) return Collections.emptyList();
        List<String> l = new ArrayList<>();
        for (String s : r.split(",")) { String t = s.trim(); if (!t.isEmpty()) l.add("/repository/" + t + "/"); }
        return l;
    }
    private static final class Snapshot { final boolean enabled; final int scopedPort; final List<String> allowedPrefixes; Snapshot(boolean e,int p,List<String> a){enabled=e;scopedPort=p;allowedPrefixes=a;} }
}
JAVA

RUN cat > /tmp/src/com/sonatype/nexus/plugins/portgate/PortGateFilter.java << 'JAVA'
package com.sonatype.nexus.plugins.portgate;
import java.io.IOException; import javax.inject.*; import javax.servlet.*; import javax.servlet.http.*; import org.slf4j.*;
@Named @Singleton
public class PortGateFilter implements Filter {
    private static final Logger log = LoggerFactory.getLogger(PortGateFilter.class);
    private final PortGateConfig config;
    @Inject public PortGateFilter(PortGateConfig c) { config = c; }
    public void init(FilterConfig f) { log.info("Port-gate filter ready"); }
    public void doFilter(ServletRequest q, ServletResponse s, FilterChain c) throws IOException, ServletException {
        int port = q.getLocalPort();
        if (port == config.getScopedPort() && config.isEnabled()) {
            String path = ((HttpServletRequest)q).getRequestURI();
            for (String p : config.getAllowedPrefixes()) if (path.startsWith(p)) { c.doFilter(q,s); return; }
            HttpServletResponse h = (HttpServletResponse)s; h.setStatus(403); h.setContentType("text/plain");
            h.getWriter().write("Port-gate: denied on port "+port+" for "+path+"\n"); return;
        }
        c.doFilter(q,s);
    }
    public void destroy() {}
}
JAVA

RUN cat > /tmp/src/com/sonatype/nexus/plugins/portgate/PortGateCapability.java << 'JAVA'
package com.sonatype.nexus.plugins.portgate;
import java.util.*; import javax.inject.*; import org.sonatype.nexus.capability.CapabilitySupport; import org.slf4j.*;
@Named("agent-trust.port-gate") @Singleton
public class PortGateCapability extends CapabilitySupport<PortGateCapability.Cfg> {
    public static final String TYPE_ID = "agent-trust.port-gate";
    private final PortGateConfig cfg;
    @Inject public PortGateCapability(PortGateConfig c) { cfg = c; }
    @Override protected Cfg createConfig(Map<String,String> p) throws Exception {
        int port=8443; try{port=Integer.parseInt(p.getOrDefault("scopedPort","8443").trim());}catch(Exception e){}
        return new Cfg(port, PortGateConfig.parseRepos(p.getOrDefault("enabledRepos","")));
    }
    @Override protected void onUpdate(Cfg c) throws Exception { cfg.update(true,c.port,c.paths); }
    @Override protected void onActivate(Cfg c) throws Exception { cfg.update(true,c.port,c.paths); }
    @Override protected void onPassivate(Cfg c) throws Exception { cfg.clear(); }
    @Override protected void onRemove(Cfg c) throws Exception { cfg.clear(); }
    static final class Cfg { final int port; final List<String> paths; Cfg(int p,List<String> a){port=p;paths=a;} }
}
JAVA

RUN cat > /tmp/src/com/sonatype/nexus/plugins/portgate/PortGateCapabilityDescriptor.java << 'JAVA'
package com.sonatype.nexus.plugins.portgate;
import java.util.*; import javax.inject.*;
import org.sonatype.nexus.capability.*; import org.sonatype.nexus.formfields.*;
import org.sonatype.nexus.common.upgrade.AvailabilityVersion;

@AvailabilityVersion(from = "1.0")
@Named("port-gate-descriptor") @Singleton
public class PortGateCapabilityDescriptor extends CapabilityDescriptorSupport {
    private final NumberTextFormField portField;
    private final ItemselectFormField reposField;

    public PortGateCapabilityDescriptor() {
        portField = new NumberTextFormField(
            "scopedPort", "Scoped port",
            "Nexus port that receives agent traffic.",
            FormField.MANDATORY);
        portField.withInitialValue(8443);

        reposField = new ItemselectFormField(
            "enabledRepos", "Enabled repositories",
            "Move repositories from Available to Enabled to allow agent access on the scoped port.",
            FormField.MANDATORY);
        reposField.setStoreApi("coreui_Repository.read");
        reposField.setIdMapping("name");
        reposField.setNameMapping("name");
        reposField.getAttributes().put("fromTitle", "Available");
        reposField.getAttributes().put("toTitle", "Enabled");
        reposField.getAttributes().put("buttons", java.util.List.of("add", "remove", "addAll", "removeAll"));
    }

    @Override public CapabilityType type() { return new CapabilityType(PortGateCapability.TYPE_ID); }
    @Override public String name() { return "Agent Trust: Port Gate"; }
    @Override public int version() { return 1; }
    @Override public String about() {
        return "Enable or disable individual repositories for agent access on a scoped port. " +
               "Disabled repositories return 403 on the scoped port.";
    }
    @Override public List<FormField> formFields() { return List.of(portField, reposField); }
    @Override @SuppressWarnings("rawtypes") protected Object createConfig(Map p) { return p; }
}
JAVA

# Compile
RUN cd /tmp/cp && jar xf /opt/sonatype/nexus/bin/sonatype-nexus-repository-*.jar BOOT-INF/lib && \
    cp BOOT-INF/lib/*.jar . && rm -rf BOOT-INF && \
    javac -cp "/tmp/cp/*" -d /tmp/build $(find /tmp/src -name '*.java') && \
    echo "Compiled $(find /tmp/build -name '*.class' | wc -l) classes"

# Package
RUN mkdir -p /tmp/build/META-INF/sisu && \
    printf "com.sonatype.nexus.plugins.portgate.PortGateFilter\ncom.sonatype.nexus.plugins.portgate.PortGateConfig\ncom.sonatype.nexus.plugins.portgate.PortGateCapability\ncom.sonatype.nexus.plugins.portgate.PortGateCapabilityDescriptor\n" > /tmp/build/META-INF/sisu/javax.inject.Named && \
    mkdir -p /opt/sonatype/nexus/plugins && \
    jar cf /opt/sonatype/nexus/plugins/port-gate-plugin.jar -C /tmp/build .

# loader.properties
RUN printf "loader.path=BOOT-INF/classes,BOOT-INF/lib,/opt/sonatype/nexus/plugins\n" > /tmp/loader.properties && \
    cd /tmp && jar uf /opt/sonatype/nexus/bin/sonatype-nexus-repository-*.jar loader.properties

RUN chown -R nexus:nexus /nexus-data && rm -rf /tmp/*

USER nexus
